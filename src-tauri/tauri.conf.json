{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../",
    "distDir": "../",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "ZenWidget",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "startDragging": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "identifier": "com.zenwidget.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "shortDescription": "Relaxing mini-games widget",
      "longDescription": "A floating widget with a collection of relaxing mini-games. Perfect for micro-breaks during work or study.",
      "macOS": {
        "minimumSystemVersion": "10.15"
      },
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "label": "main",
        "title": "ZenWidget",
        "width": 360,
        "height": 316,
        "minWidth": 280,
        "minHeight": 240,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "x": 40,
        "y": 40
      }
    ]
  }
}
